#!/usr/bin/env ruby

require_relative "../config/environment"
# The jobs process delivers Discord messages over REST (e.g. reminders), so load
# the Discord client once at boot instead of lazily per job. discordrb stays
# require:false in the Gemfile to keep web/console/rake lean.
require "discordrb"
require "solid_queue/cli"

SolidQueue::Cli.start(ARGV)
